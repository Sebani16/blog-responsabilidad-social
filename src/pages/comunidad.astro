---
import MainLayout from '../layouts/MainLayout.astro';
import GoogleMap from '../components/GoogleMap.astro';
---
<MainLayout title="Comunidad" description="Información sobre la comunidad de Ciudad Guabinas">
  <section class="content-section">
    <div class="glass-panel text-content animate-fade-in-up" style="animation-delay: 0.2s;">
      <h2>Nuestra Comunidad: Ciudad Guabinas</h2>
      <p>
        Ciudad Guabinas es el enfoque principal de nuestro proyecto de responsabilidad social.
        A continuación, puedes examinar la ubicación y el área circundante de la comunidad interactuando con este mapa dinámico:
      </p>
    </div>
    
    <div class="map-wrapper dynamic-card animate-fade-in-up" style="animation-delay: 0.4s;">
      <GoogleMap />
    </div>
  </section>
</MainLayout>

<style>
  .content-section {
    padding: 2rem 0;
    max-width: 1000px;
    margin: 0 auto;
  }
  .text-content {
    padding: 3rem 2rem;
    text-align: center;
    border-top: 6px solid var(--color-action-orange);
    margin-bottom: 3rem;
  }
  .text-content h2 {
    color: var(--color-action-orange);
    margin-bottom: 1.5rem;
    font-size: 2.4rem;
    font-weight: 800;
  }
  .text-content p {
    font-size: 1.2rem;
    color: var(--color-text);
    line-height: 1.8;
    margin: 0;
  }
  .map-wrapper {
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.05);
    background: white;
  }
</style>
