---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout 
  title="Video" 
  description="Presentación audiovisual del proyecto"
>
  <section class="video-section glass-panel animate-fade-in-up" style="animation-delay: 0.2s;">
    <h2 class="video-title">Video del Proyecto</h2>
    <div class="video-description text-left">
      <p>A continuación, te invitamos a ver el siguiente video donde se captura la esencia de nuestro Proyecto Social de Formación y las actividades desarrolladas.</p>
    </div>
    
    <div class="iframe-wrapper dynamic-card animate-fade-in-up" style="animation-delay: 0.4s;">
      <iframe 
        width="560" 
        height="315" 
        src="https://www.youtube.com/embed/7Co-tp3ffI8" 
        title="YouTube video player" 
        frameborder="0" 
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
        referrerpolicy="strict-origin-when-cross-origin" 
        allowfullscreen>
      </iframe>
    </div>
  </section>
</MainLayout>

<style>
  .video-section {
    text-align: center;
    padding: 3.5rem 2rem;
    margin: 2rem auto;
    max-width: 1000px;
    border-top: 6px solid var(--color-accent-green);
  }
  .video-title {
    color: var(--color-primary-blue);
    margin-bottom: 2rem;
    font-size: 2.2rem;
    font-weight: 800;
    line-height: 1.3;
  }
  .text-left {
    text-align: left;
  }
  .video-description {
    font-size: 1.15rem;
    max-width: 850px;
    margin: 0 auto 3rem auto;
    color: var(--color-text);
    line-height: 1.8;
  }
  .video-description p {
    margin-bottom: 1.5rem;
  }
  .iframe-wrapper {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
    height: 0;
    overflow: hidden;
    max-width: 850px;
    margin: 0 auto;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }
  .iframe-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
</style>
