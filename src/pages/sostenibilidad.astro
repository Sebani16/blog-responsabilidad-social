---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Sostenibilidad" description="Sostenibilidad de la Actividad">
  <section class="content-section">
    <div
      class="glass-panel header-panel animate-fade-in-up"
      style="animation-delay: 0.2s;"
    >
      <h2>
        🌿 Pulmones Verdes: Huerta Medicinal para la Resiliencia Familiar en
        Ciudad Guabinas.
      </h2>
      <p class="intro">
        El proceso de análisis multidimensional sobre las problemáticas en
        Ciudad Guabinas (Yumbo) generó una profunda empatía y responsabilidad al
        ser conscientes de la afectación por la presión industrial de su
        entorno.
      </p>
    </div>
  </section>
</MainLayout>

<style>
  .content-section {
    padding: 2rem 0;
  }
  .header-panel {
    padding: 3rem 2rem;
    text-align: center;
    margin-bottom: 3.5rem;
    border-top: 6px solid var(--color-primary-blue);
    margin-inline: 1rem;
  }
  .header-panel h2 {
    color: var(--color-primary-blue);
    margin-bottom: 1.5rem;
    font-size: 2.4rem;
    font-weight: 800;
  }
  .intro {
    font-size: 1.25rem;
    color: var(--color-text);
    margin-bottom: 0;
    max-width: 800px;
    margin-inline: auto;
    line-height: 1.8;
  }
  .card-container {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    padding: 1rem;
  }
  .card {
    background: white;
    padding: 2.5rem;
    border-radius: 16px;
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }
  .objective-general {
    border-left: 8px solid var(--color-highlight-yellow);
  }
  .objective-specific {
    border-left: 8px solid var(--color-accent-green);
  }

  .card-icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    flex-shrink: 0;
    color: white;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  }
  .bg-yellow {
    background: var(--color-highlight-yellow);
    color: var(--color-text);
  }
  .bg-green {
    background: var(--color-accent-green);
  }

  .card-content h3 {
    margin-top: 0;
    font-size: 1.8rem;
    margin-bottom: 1rem;
    font-weight: 800;
    color: var(--color-text);
  }
  .card-content p,
  .card-content ul {
    line-height: 1.7;
    color: #4a5568;
    font-size: 1.1rem;
    margin: 0;
  }
  .card-content ul {
    padding-left: 1.5rem;
  }
  .card-content li {
    margin-bottom: 0.8rem;
  }

  @media (max-width: 768px) {
    .card {
      flex-direction: column;
      gap: 1.5rem;
      padding: 2rem;
    }
  }
</style>
