---
import BaseHead from '../components/BaseHead.astro';
import Navigation from '../components/Navigation.astro';

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
	<head>
		<BaseHead title={`${title} | Pulmones Verdes`} description={description} />
	</head>
	<body>
    <header class="site-header" id="main-header">
      <div class="header-brand animate-fade-in-up">
        <h1>Pulmones Verdes: Huerta Medicinal para la Resiliencia Familiar en Ciudad Guabinas</h1>
        <p class="subtitle">Familia Moreno Martínez</p>
      </div>
      <div class="nav-wrapper">
        <Navigation />
      </div>
    </header>
		<main class="container animate-fade-in-up" style="animation-delay: 0.15s;">
			<slot />
		</main>
    <footer>
      <div class="footer-content">
        <p>&copy; {new Date().getFullYear()} Proyecto de Responsabilidad Social.</p>
        <div class="footer-accent-line"></div>
      </div>
    </footer>

    <script>
      // Collapses the large header when the user scrolls down the page
      const setupHeaderScroll = () => {
        const header = document.getElementById('main-header');
        if(!header) return;
        
        window.addEventListener('scroll', () => {
          if (window.scrollY > 40) {
            header.classList.add('scrolled');
          } else {
            header.classList.remove('scrolled');
          }
        }, { passive: true });
      }
      
      setupHeaderScroll();
    </script>
	</body>
</html>

<style>
  .site-header {
    background: linear-gradient(135deg, var(--color-primary-blue), var(--color-secondary-green));
    position: sticky;
    top: 0;
    z-index: 1000;
    box-shadow: 0 8px 30px rgba(0,80,139,0.3);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .header-brand {
    padding: 2.5rem 1rem 1.5rem 1rem;
    text-align: center;
    max-width: 1200px;
    margin: 0 auto;
    color: white;
    transition: padding 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  h1 {
    color: white;
    margin: 0;
    font-size: 2.2rem;
    font-weight: 800;
    letter-spacing: -1px;
    text-shadow: 0 4px 15px rgba(0,0,0,0.3);
    line-height: 1.3;
    transition: font-size 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .subtitle {
    color: var(--color-highlight-yellow);
    font-size: 1.3rem;
    font-weight: 600;
    margin-top: 1rem;
    opacity: 0.95;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    max-height: 50px;
    overflow: hidden;
  }
  .nav-wrapper {
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(12px);
    border-top: 1px solid rgba(255,255,255,0.2);
  }
  
  /* --- ESTADOS DEL HEADER CONTRAÍDO (SCROLLED) --- */
  .site-header.scrolled {
    box-shadow: 0 10px 40px rgba(0,80,139,0.5);
  }
  .site-header.scrolled .header-brand {
    padding: 0.8rem 1rem 0.5rem 1rem;
  }
  .site-header.scrolled h1 {
    font-size: 1.3rem;
    text-shadow: none;
    line-height: 1;
  }
  .site-header.scrolled .subtitle {
    opacity: 0;
    margin-top: 0;
    max-height: 0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3.5rem 1rem;
    min-height: 60vh;
  }
  footer {
    background: linear-gradient(to right, #1a202c, var(--color-primary-blue));
    color: white;
    text-align: center;
    margin-top: 5rem;
  }
  .footer-content {
    padding: 4rem 1rem;
    background: rgba(0,0,0,0.3);
    position: relative;
    font-size: 1.1rem;
    letter-spacing: 0.5px;
  }
  .footer-accent-line {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 6px;
    background: linear-gradient(to right, var(--color-accent-green), var(--color-highlight-yellow), var(--color-action-orange));
  }
  
  @media (max-width: 768px) {
    h1 {
      font-size: 1.8rem;
    }
    .site-header.scrolled h1 {
      font-size: 1.15rem;
    }
  }
</style>
