---
// Google Maps API integration removed.
// Renderizamos un placeholder para una imagen estática del mapa.
---
<div class="map-placeholder dynamic-card">
  <div class="overlay-text">
    <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
      <circle cx="12" cy="10" r="3"></circle>
    </svg>
    <h3>Mapa de Ciudad Guabinas</h3>
    <p>[Espacio reservado para insertar imagen estática del croquis o mapa local]</p>
  </div>
  <img src="https://picsum.photos/seed/map/1000/500" alt="Placeholder del Mapa" class="map-image" />
</div>

<style>
  .map-placeholder {
    width: 100%;
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background-color: #2d3748;
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
  }
  .map-image {
    width: 100%;
    display: block;
    height: 450px;
    object-fit: cover;
    opacity: 0.35;
    transition: opacity 0.4s ease;
  }
  .map-placeholder:hover .map-image {
    opacity: 0.55;
  }
  .overlay-text {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: white;
    z-index: 10;
    padding: 2.5rem;
    pointer-events: none;
    text-shadow: 0 2px 8px rgba(0,0,0,0.6);
  }
  .overlay-text svg {
    margin-bottom: 1rem;
    color: var(--color-highlight-yellow);
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.5));
  }
  .overlay-text h3 {
    font-size: 2.2rem;
    margin: 0 0 0.8rem 0;
    font-weight: 800;
  }
  .overlay-text p {
    font-size: 1.2rem;
    margin: 0;
    max-width: 500px;
    opacity: 0.9;
  }
</style>
