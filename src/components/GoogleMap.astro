---
// Obtenemos la llave desde las variables de entorno
const apiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY;
---

<div class="map-container dynamic-card">
  {apiKey && apiKey !== "YOUR_API_KEY_HERE" ? (
    <iframe
      width="100%"
      height="450"
      class="map-iframe"
      loading="lazy"
      allowfullscreen
      referrerpolicy="no-referrer-when-downgrade"
      src={`https://www.google.com/maps/embed/v1/place?key=${apiKey}&q=Ciudad+Guabinas,Yumbo,Valle+del+Cauca,Colombia`}>
    </iframe>
  ) : (
    <div class="map-placeholder">
      <div class="overlay-text">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
          <circle cx="12" cy="10" r="3"></circle>
        </svg>
        <h3>API Key Faltante</h3>
        <p>Añade tu API Key en el archivo <code>.env</code> para habilitar el mapa de Ciudad Guabinas.</p>
      </div>
    </div>
  )}
</div>

<style>
  .map-container {
    width: 100%;
    border-radius: 16px;
    overflow: hidden;
    background-color: #2d3748;
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
  }
  .map-iframe {
    border: 0;
    display: block;
  }
  .map-placeholder {
    height: 450px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(circle at center, rgba(255, 255, 255, 0.1), transparent);
  }
  .overlay-text {
    text-align: center;
    color: white;
    padding: 2rem;
  }
  .overlay-text svg {
    margin-bottom: 1rem;
    color: var(--color-action-orange);
  }
  .overlay-text h3 {
    font-size: 1.8rem;
    margin: 0 0 0.5rem 0;
    font-weight: 800;
  }
  .overlay-text p {
    font-size: 1.1rem;
    opacity: 0.9;
  }
  .overlay-text code {
    background: rgba(0,0,0,0.3);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    color: var(--color-highlight-yellow);
  }
</style>
